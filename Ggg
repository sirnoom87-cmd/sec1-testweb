<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>เพลงเพิ่มเติม | GuitarChordViews</title>

<style>
:root{
  --bg:#f1eded;
  --bg2:#d9d4d4;
  --card:#5f5f5f;
  --hover:#6fa0a0;
  --text:#222;
  --nav:#3f3f3f;
  --sub:#ccc;
  --accent:#6fa0a0;
}
body.dark{
  --bg:#0f0f0f;
  --bg2:#1a1a1a;
  --card:#2b2b2b;
  --hover:#4f8a8a;
  --text:#eee;
  --nav:#000;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Arial,sans-serif;
  color:var(--text);
  min-height:100vh;
  background:linear-gradient(180deg,var(--bg),var(--bg2));
}

/* ===== NAV ===== */
nav{
  position:sticky;top:0;z-index:10;
  height:100px;
  background:linear-gradient(90deg,var(--nav),#777);
  display:flex;align-items:center;
  padding:0 40px;color:white;
}
.nav-left a{
  color:white;text-decoration:none;
  padding:10px 22px;
  background:rgba(255,255,255,.15);
  border-radius:25px;font-weight:bold;
}
.nav-center{
  position:absolute;left:50%;
  transform:translateX(-50%);
  display:flex;gap:20px;align-items:center;
}
.nav-center img{
  width:60px;height:60px;border-radius:50%;background:white;
}
.nav-center span{font-size:28px;font-weight:bold;}
.nav-right{margin-left:auto;display:flex;gap:10px;}
.theme-btn{
  border:none;padding:8px 16px;
  border-radius:20px;cursor:pointer;
}

/* ===== CONTENT ===== */
.container{max-width:1200px;margin:auto;padding:50px 20px;}
h1{text-align:center;margin-bottom:40px;}

/* ===== GRID ===== */
.song-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:30px;
}
@media(max-width:900px){
  .song-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:600px){
  .song-grid{grid-template-columns:1fr;}
}

/* ===== CARD ===== */
.song-card{
  background:var(--card);
  border-radius:28px;
  overflow:hidden;color:white;
  box-shadow:0 14px 32px rgba(0,0,0,.35);
  transition:.3s;
}
.song-card:hover{
  transform:translateY(-10px);
  background:var(--hover);
}
.song-card img{
  width:100%;height:200px;object-fit:cover;
}
.song-info{text-align:center;padding:20px;}
.song-title{font-size:20px;font-weight:bold;}
.song-artist{color:var(--sub);margin:6px 0 12px;}
.open-btn{
  display:inline-block;
  padding:8px 20px;
  background:var(--accent);
  color:white;border-radius:20px;
  text-decoration:none;font-size:14px;
}

/* ===== FAVORITE ===== */
.heart{margin-top:14px;cursor:pointer;font-size:22px;}
.heart.active{color:#ff4d6d;}
.count{font-size:14px;margin-left:6px;}

/* ===== COMMENT ===== */
.comment-box{margin-top:12px;}
.comment-box input{
  width:100%;padding:6px;border-radius:10px;border:none;
}
.comment-list{
  margin-top:8px;font-size:13px;text-align:left;
}

/* ===== FOOTER ===== */
footer{
  margin-top:80px;padding:30px;
  text-align:center;background:var(--nav);color:white;
}
</style>
</head>

<body>

<nav>
  <div class="nav-left"><a href="หน้าหลัก.html">กลับหน้าหลัก</a></div>
  <div class="nav-center">
    <img src="logo.png">
    <span>GuitarChordViews</span>
  </div>
  <div class="nav-right">
    <button class="theme-btn" onclick="toggleDark()">🌙/☀️</button>
  </div>
</nav>

<div class="container">
<h1>🎶 เพลงเพิ่มเติม</h1>

<div class="song-grid">

<!-- ใช้โครงนี้ซ้ำ เพิ่มเพลงได้ -->
<div class="song-card" data-id="song1">
  <img src="img/ถ้า.jpg">
  <div class="song-info">
    <div class="song-title">ถ้าเธอรักจริง</div>
    <div class="song-artist">Three Man Down</div>
    <a class="open-btn" href="https://www.docchord.com" target="_blank">ไปที่ Docchord</a>
    <div class="heart">❤️ <span class="count">0</span></div>

    <div class="comment-box">
      <input placeholder="แสดงความคิดเห็นแล้วกด Enter">
      <div class="comment-list"></div>
    </div>
  </div>
</div>

<!-- ทำซ้ำจนครบ 6 เพลง -->
<div class="song-card" data-id="song2">…</div>
<div class="song-card" data-id="song3">…</div>
<div class="song-card" data-id="song4">…</div>
<div class="song-card" data-id="song5">…</div>
<div class="song-card" data-id="song6">…</div>

</div>
</div>

<footer>GuitarChordViews | เพลงกีตาร์</footer>

<script>
document.querySelectorAll(".song-card").forEach(card=>{
  const id = card.dataset.id;
  const heart = card.querySelector(".heart");
  const countEl = card.querySelector(".count");

  let count = localStorage.getItem(id+"_count") || 0;
  countEl.textContent = count;

  heart.onclick = ()=>{
    heart.classList.toggle("active");
    count = heart.classList.contains("active") ? ++count : --count;
    if(count<0) count=0;
    countEl.textContent = count;
    localStorage.setItem(id+"_count",count);
  };

  const input = card.querySelector("input");
  const list = card.querySelector(".comment-list");
  const comments = JSON.parse(localStorage.getItem(id+"_comments")||"[]");
  comments.forEach(c=>list.innerHTML+=`<div>- ${c}</div>`);

  input.addEventListener("keypress",e=>{
    if(e.key==="Enter" && input.value){
      comments.push(input.value);
      localStorage.setItem(id+"_comments",JSON.stringify(comments));
      list.innerHTML+=`<div>- ${input.value}</div>`;
      input.value="";
    }
  });
});

function toggleDark(){
  document.body.classList.toggle("dark");
}
</script>

</body>
</html>
